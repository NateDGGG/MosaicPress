{
  "name": "@mosaic/core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared core for Mosaic: lib, components, routes, schema, scripts.",
  "exports": {
    "./app/*": ["./src/app/*.tsx", "./src/app/*.ts"],
    "./components/*": ["./src/components/*.tsx", "./src/components/*.ts"],
    "./lib/*": ["./src/lib/*.ts", "./src/lib/*.tsx"],
    "./styles/*": "./src/styles/*",
    "./prisma/*": "./prisma/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@prisma/client": "^5.18.0",
    "cheerio": "^1.0.0",
    "nodemailer": "^6.9.14",
    "stripe": "^16.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "peerDependencies": {
    "next": "^14",
    "react": "^18",
    "react-dom": "^18"
  }
}
