{
  "name": "mosaic-learn",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable, all-in-one multimedia CMS — hosted & external content, side-by-side.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "prisma generate && prisma db push && tsx prisma/seed.ts",
    "sync": "tsx scripts/sync.ts",
    "publish:due": "tsx scripts/publish-due.ts",
    "db:provider": "node scripts/set-provider.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@prisma/client": "^5.18.0",
    "cheerio": "^1.0.0",
    "next": "14.2.35",
    "nodemailer": "^6.9.14",
    "stripe": "^16.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
