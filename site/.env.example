# Copy to .env and fill in.

# Database. For local SQLite (default) leave provider unset / "sqlite".
# For PostgreSQL set DATABASE_PROVIDER=postgresql and a postgres DATABASE_URL,
# then run `npm run db:provider` before generate/push (Docker does this for you).
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"
# Example Postgres:
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://mosaic:mosaic@localhost:5432/mosaic?schema=public"

# Public base URL (used for Stripe redirect URLs, etc.)
APP_URL="http://localhost:3000"

# Secret used to sign session cookies. Generate: openssl rand -hex 32
SESSION_SECRET="dev-insecure-change-me-please-0123456789abcdef"

# Stripe — leave blank to run checkout in STUB mode (no real charges).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Default owner created by the seed (change after first login).
SEED_OWNER_EMAIL="owner@example.com"
SEED_OWNER_PASSWORD="changeme123"

# Media storage. Default "local" (public/uploads). Set "s3" for S3-compatible
# storage (AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces).
MEDIA_BACKEND="local"
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# For non-AWS S3-compatible services, set the endpoint (and often path style):
S3_ENDPOINT=""
S3_FORCE_PATH_STYLE="false"
S3_PREFIX="uploads"
# Public base URL for serving objects (CDN domain or bucket URL). Optional.
S3_PUBLIC_URL=""

# Email (transactional receipts + digital delivery).
# Leave SMTP_HOST blank to run in STUB mode (logs emails, doesn't send).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Mosaic <no-reply@example.com>"
